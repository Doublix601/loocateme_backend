# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:19006

# MongoDB
MONGODB_URI=mongodb://mongo:27017/loocateme
MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/loocateme

# JWT
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Redis
REDIS_URL=redis://redis:6379
REDIS_URL_LOCAL=redis://127.0.0.1:6379

# Uploads
UPLOAD_DIR=uploads
BASE_URL=http://localhost:4000

# Public URLs
APP_PUBLIC_URL=https://loocate.me
# Optional override for the link sent in privacy policy update emails; defaults to APP_PUBLIC_URL + /privacy
PRIVACY_POLICY_URL=

# Comptes professionnels (site Web loocateme_website, sous-domaine dédié pour le cookie refreshToken cross-subdomain)
BUSINESS_SITE_PUBLIC_URL=https://pro.loocate.me
BUSINESS_ACTIVATION_TOKEN_TTL=7d
# Dossier privé (hors /uploads) pour les documents de candidature pro (KBIS, pièce d'identité)
BUSINESS_DOCS_DIR=data/business-docs

# Site public grand public (loocateme_public_website), pour l'allowlist CORS
PUBLIC_SITE_PUBLIC_URL=https://loocate.me
# Boîte mail qui reçoit les messages du formulaire de contact/support du site public
SUPPORT_INBOX=support@loocate.me

# Stripe (abonnements Web des comptes pro, indépendant de RevenueCat/IAP mobile)
STRIPE_SECRET_KEY=sk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me
STRIPE_PRICE_PRO1=price_replace-me
STRIPE_PRICE_PRO2=price_replace-me
STRIPE_PRICE_PRO3=price_replace-me
